# 認証情報
.credentials.json

# Claude Code 内部状態（agents 定義は共有するため追跡する）
.claude/*
!.claude/agents/
cache/
file-history/
history.jsonl
ide/
session-env/
sessions/
shell-snapshots/

# マシン固有データ
backups/
memory/*
!memory/.gitkeep
config.yaml

# マーケットプレイスプラグイン（再取得可能）
plugins/

# 会話履歴（大容量・個人的）
projects/

# 作業中の計画（一時的）
plans/

# git worktree（並行作業用、追跡不要）
/worktree/

# RTK 生成物（rtk init -g が各マシンで再生成）
RTK.md

# Python キャッシュ
__pycache__/
*.pyc
