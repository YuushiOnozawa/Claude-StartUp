{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git stash list)",
      "Bash(git tag)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(mkdir -p *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:x.com)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(sudo *)",
      "Bash(wget *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(* | bash)",
      "Bash(* | sh)",
      "Read(~/**/.env)",
      "Read(~/**/.env.*)",
      "Edit(~/**/.env)",
      "Edit(~/**/.env.*)",
      "Write(~/**/.env)",
      "Write(~/**/.env.*)",
      "Bash(cat .env*)",
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Bash(cat ~/.ssh/*)",
      "Read(~/.claude/.credentials.json)",
      "Edit(~/.claude/.credentials.json)",
      "Write(~/.claude/.credentials.json)",
      "Read(~/**/rclone.conf)",
      "Edit(~/**/rclone.conf)",
      "Write(~/**/rclone.conf)",
      "Bash(*rclone.conf*)",
      "Bash(*rclone*sync*)",
      "Bash(*rclone*delete*)",
      "Bash(*rclone*purge*)",
      "Bash(*rclone*move*)",
      "Bash(*rclone*bisync*)",
      "Bash(*rclone*cleanup*)",
      "Bash(*rclone*dedupe*)"
    ]
  },
  "effortLevel": "medium",
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/knowledge-distill.sh 2>> ~/.claude/hooks/logs/knowledge-distill.log"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-end-queue.sh 2>> ~/.claude/hooks/logs/session-end-queue.log"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f ~/.claude/hooks/error-detector.sh ] && bash ~/.claude/hooks/error-detector.sh || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  }
}
